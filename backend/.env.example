# ─── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-in-production-!
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Bunny Stream (video hosting) ────────────────────────────────────────────
# Get these from: https://dash.bunny.net → Stream → your library → Security tab

# Numeric Library ID (e.g. 123456) — shown at the top of the library page
BUNNY_LIBRARY_ID=

# Token Authentication Key — Stream library → Security tab → "Token Authentication"
# Enable Token Authentication first, then copy the key shown there.
# ⚠️  This is NOT the same as the Library API Key (AccessKey).
BUNNY_SECURITY_KEY=

# Library API Key (AccessKey) — used ONLY for uploading videos via the admin panel.
# Stream library → API tab → "API Key"
BUNNY_STREAM_API_KEY=

# Pull Zone hostname — e.g. vz-xxxxxx.b-cdn.net (optional, used for direct CDN links)
BUNNY_CDN_HOSTNAME=

# Multi-library support (optional):
# Keep BUNNY_LIBRARY_ID / BUNNY_SECURITY_KEY / BUNNY_STREAM_API_KEY for the default library.
# For ANY other library id, add per-library keys (no allowlist required):
# BUNNY_SECURITY_KEY_123456=token_key_for_that_library
# BUNNY_STREAM_API_KEY_123456=api_key_for_that_library
# Optional convenience list (not required if per-library keys exist):
# BUNNY_ADDITIONAL_LIBRARY_IDS=631057,700123
BUNNY_ADDITIONAL_LIBRARY_IDS=

# ─── Cloudinary (image/file storage, optional) ──────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Database (leave blank to use local SQLite) ──────────────────────────────
# DATABASE_URL=postgres://user:pass@host:5432/dbname
